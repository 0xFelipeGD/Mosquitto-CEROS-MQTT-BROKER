# Mosquitto ACL — ROS2-RCS Twin
# Three users: rcs_operator (PC/tablet), ugv_client (Jetson), health (internal)
#
# All twin traffic happens under `ugv/` prefix (legacy from Remote_Control compatibility).
# Reload after editing: docker compose restart mosquitto

# Health check user — read-only on $SYS
user health
topic read $SYS/#

# RCS operator (Electron app on PC/tablet)
user rcs_operator
topic readwrite ugv/cmd_vel
topic readwrite ugv/heartbeat
topic read ugv/odom
topic read ugv/fix
topic read ugv/rtk_status
topic read ugv/e_stop_status
topic read ugv/plc_status
topic read ugv/motor/#
topic read ugv/battery/#
topic read ugv/sensors/#
topic read ugv/detections
topic readwrite ugv/webrtc/+
topic readwrite ugv/waypoints

# UGV client (Jetson's mqtt_client bridge)
user ugv_client
topic readwrite ugv/cmd_vel
topic readwrite ugv/heartbeat
topic write ugv/odom
topic write ugv/fix
topic write ugv/rtk_status
topic write ugv/e_stop_status
topic write ugv/plc_status
topic write ugv/motor/#
topic write ugv/battery/#
topic write ugv/sensors/#
topic write ugv/detections
topic readwrite ugv/webrtc/+
topic read ugv/waypoints
